{
  "name": "morpheus",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "doppler run -- bun src/index.ts live",
    "live": "doppler run -- bun src/index.ts live",
    "backfill": "doppler run -- bun src/index.ts backfill",
    "reconcile": "doppler run -- bun src/index.ts reconcile",
    "reindex": "doppler run -- bun src/index.ts reindex",
    "rotate": "doppler run -- bun src/index.ts rotate",
    "list-channels": "doppler run -- bun scripts/list-channels.ts",
    "register-nia": "doppler run -- bun scripts/register-nia-source.ts",
    "refresh-members": "doppler run -- bun scripts/refresh-members.ts",
    "build:sandbox": "bash scripts/build-sandbox-image.sh",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "bottleneck": "^2.19.5",
    "discord.js": "^14.16.3",
    "node-cron": "^3.0.3",
    "openai": "^6.35.0",
    "pino": "^9.5.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/node-cron": "^3.0.11",
    "bun-types": "^1.1.0",
    "pino-pretty": "^11.2.2",
    "typescript": "^5.6.3",
    "@types/bun": "latest"
  },
  "module": "src/index.ts"
}
