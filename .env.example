# Morpheus Discord intelligence bot — environment variables
#
# This file is committed for documentation only. At runtime, secrets are
# injected by Doppler:    doppler run -- bun src/index.ts <cmd>
# Do NOT create a real .env in this repo. .gitignore covers it as a safety net.

# --- Discord (Discord Developer Portal -> Bot tab) ---
DISCORD_TOKEN=                     # bot token; never commit
DISCORD_GUILD_ID=                  # numeric guild snowflake

# --- NVIDIA NIM (build.nvidia.com -> Settings -> API Keys) ---
NVIDIA_API_KEY=

# --- Nia (api.trynia.ai) ---
NIA_API_KEY=
NIA_BASE_URL=https://api.trynia.ai
NIA_DISCORD_SOURCE_ID=             # populated by `bun run register-nia` after first setup

# --- Runtime tunables ---
LOG_LEVEL=info                     # pino level: trace|debug|info|warn|error|fatal
HEALTH_PORT=8080                   # /health endpoint
RETENTION_MONTHS=                  # blank = no rotation (default)
NODE_ENV=development               # set to "production" on hosted deploys
